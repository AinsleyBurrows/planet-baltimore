{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the conversation panel"
    },
    "description": {
      "type": "string",
      "description": "Optional description / topic"
    },
    "image_url": {
      "type": "string",
      "description": "Optional image for the conversation"
    },
    "location": {
      "type": "string",
      "description": "Optional location / stage label"
    },
    "scheduled_time": {
      "type": "string",
      "description": "Optional scheduled time label (e.g. '3:00 PM')"
    },
    "rsvp_count": {
      "type": "number",
      "default": 0
    },
    "rsvped_user_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "title"
  ]
}