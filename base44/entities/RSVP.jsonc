{
  "name": "RSVP",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "going",
        "interested",
        "not_going"
      ],
      "default": "going"
    }
  },
  "required": [
    "user_id",
    "event_id"
  ]
}