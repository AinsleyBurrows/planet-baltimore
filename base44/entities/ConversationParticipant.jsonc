{
  "name": "ConversationParticipant",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string",
      "description": "Reference to Conversation"
    },
    "name": {
      "type": "string",
      "description": "Name of the participant"
    },
    "role": {
      "type": "string",
      "description": "Optional role / title (e.g. 'Moderator', 'Panelist')"
    },
    "bio": {
      "type": "string",
      "description": "Optional short bio"
    },
    "image_url": {
      "type": "string",
      "description": "Optional image of the participant"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "conversation_id",
    "name"
  ]
}